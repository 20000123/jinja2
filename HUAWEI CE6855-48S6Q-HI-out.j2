{# 聚合口配置 #}
{% if out_switch.to_iin and out_switch.to_iin != '' %}
interface Eth-Trunk99
 port link-type trunk
 port trunk allow-pass vlan 10 20
 mode lacp-dynamic
{% endif %}
{# 聚合口配置结束 #}
#
{#全端口配置开始#}
{% for port_num in range(1, 49) %}
{% set port_name = '10GE1/0/' ~ port_num %}
interface {{ port_name }}
{% set ns = namespace(is_upper=false, is_server_port=false) %}
{# 判断1：是否为上联口 upper_list #}
{% for upper in data.api_json.new_upper_list %}
{% if upper.switch_port == port_name %}
{% set ns.is_upper = true %}
 undo portswitch
 description TO_ISP
 ipv6 enable
{% set upper_ip_addr = upper.ip.split('/')[0] %}
 ip address {{ upper_ip_addr }} 255.255.255.252
{% if upper.ipv6 %}
 ipv6 address {{ upper.ipv6 }}
{% endif %}
 qos wrr 0 to 4
 qos queue 0 wrr weight 25
 qos queue 3 wrr weight 100
 device transceiver 10GBASE-FIBER
{% endif %}
{% endfor %}

{# 判断2：非上联口 → 服务器端口 #}
{% if not ns.is_upper %}
{% for server in data.api_json.new_server_list %}
{% if server.switch_port1.sn == out_sn and server.switch_port1.port == port_name %}
{% set ns.is_server_port = true %}
 port default vlan 10
 trust dscp
 device transceiver 10GBASE-COPPER
{% elif server.switch_port2.sn == out_sn and server.switch_port2.port == port_name %}
{% set ns.is_server_port = true %}
{% if server.type == 'lvs' %}
 port default vlan 10
{% else %}
 port default vlan 20
{% endif %}
 trust dscp
 device transceiver 10GBASE-COPPER
{% endif %}
{% endfor %}
{% endif %}

{# 判断3：级联口 #}
{% if not ns.is_upper and not ns.is_server_port %}
{% for sw in data.api_json.new_switch_list %}
{% if sw.type == "out" and sw.sn == out_sn %}
{% if sw.to_iin %}
{% for link in sw.to_iin %}
{% if link.src.port == port_name %}
 description DownLink_{{ in_hostname }}
 eth-trunk 99
 device transceiver 10GBASE-COPPER
{% endif %}
{% endfor %}
{% endif %}
{% if sw.to_mgt %}
{% for link in sw.to_mgt %}
{% if link.src.port == port_name %}
 description {{ mg_hostname }}
 device transceiver 10GBASE-COPPER
{% endif %}
{% endfor %}
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
#
{% endfor %}
{# 遍历40G口：40GE1/0/1 到 1/0/6 #}
{% for port_num in range(1, 7) %}
{% set port_name = '40GE1/0/' ~ port_num %}
interface {{ port_name }}
{% set ns = namespace(is_upper=false) %}
{# 判断1：是否为上联口 upper_list #}
{% for upper in data.api_json.new_upper_list %}
{% if upper.switch_port == port_name %}
{% set ns.is_upper = true %}
 undo portswitch
 description TO_ISP
 ipv6 enable
{% set upper_ip_addr = upper.ip.split('/')[0] %}
 ip address {{ upper_ip_addr }} 255.255.255.252
 sflow flow collector 1
 sflow sampling-rate 4046
 sflow counter collector 1
 sflow counter interval 30
 traffic-policy policy-3001 inbound
 traffic-policy policy-3007 inbound
 qos wrr 0 to 4
 qos queue 0 wrr weight 25
 qos queue 3 wrr weight 100
 device transceiver 40GBASE-FIBER
{% if upper.ipv6 %}
 ipv6 address {{ upper.ipv6 }}
{% endif %}
{% endif %}
{% endfor %}
#
{% endfor %}
{#全端口配置结束#}
interface NULL0
