{# 聚合口配置 #}
{% if out_switch.to_iin and out_switch.to_iin != '' %}
interface AggregatePort 99
 port link-type trunk
 port trunk permit vlan 1 10 20
 link-aggregation mode dynamic
 stp edged-port
{% endif %}
{# 聚合口配置结束 #}
#
interface NULL0
#
{# vlan配置开始 #}
{% if in_switch.out_ip is defined and in_switch.out_ip and in_switch.out_ip != '' %}
interface Vlan 10
 description EX-Sevice-GW
 ip address {{ in_switch.out_ip }} {{ data.api_json.new_server_list[0].isp[0].netmask }}
{% endif %}
#
{% if in_switch.in_ip is defined and in_switch.in_ip and in_switch.in_ip != '' %}
interface Vlan 20
 description IN-Sevice-GW
 ip address {{ in_switch.in_ip }} {{data.api_json.node_list[0].ext.in_netmask}}
{% endif %}
{# vlan配置结束 #}
#
interface HundredGigE1/0/49
 port link-mode bridge
#
interface HundredGigE1/0/50
 port link-mode bridge
#
interface HundredGigE1/0/51
 port link-mode bridge
#
interface HundredGigE1/0/52
 port link-mode bridge
#
interface HundredGigE1/0/53
 port link-mode bridge
#
interface HundredGigE1/0/54
 port link-mode bridge
#
interface M-GigabitEthernet0/0/0
#
interface M-GigabitEthernet0/0/1
#
{# 端口配置 #}
{% set server_ports = [] %}
{% for server in data.api_json.new_server_list %}
{% if server.switch_port2 and server.switch_port2.sn == in_sn and server.switch_port2.port %}
{% do server_ports.append(server.switch_port2.port) %}
{% endif %}
{% endfor %}

{% for port_num in range(1, 49) -%}
{% set interface_name = "Ten-GigabitEthernet1/0/" ~ port_num %}
interface {{ interface_name }}
{% set ns = namespace(is_uplink=false) %}
{% if in_switch.to_out %}
{% for agg in in_switch.to_out %}
{% if agg.src.port == interface_name %}
{% set ns.is_uplink = true %}
 port link-mode bridge
 description DownLink_{{ out_hostname }}
 port link-type trunk
 port trunk permit vlan 1 10 20
 stp edged-port
 port link-aggregation group 99
{% endif %}
{% endfor %}
{% endif %}

{% if not ns.is_uplink and interface_name in server_ports %}
 port access vlan 20
 stp edged-port
 qos trust dscp
{% endif %}
#
{% endfor %}
{# 端口配置结束 #}
 scheduler logfile size 16
