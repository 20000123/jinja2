 description EX-ILO-Vlan
#
vlan 10
 name EX-Sevice-Vlan
 description EX-Sevice-Vlan
#
vlan 20
 name IN-Sevice-Vlan
 description IN-Sevice-Vlan
#
traffic classifier match-hpri-traffic operator and
 if-match acl 3066
#
traffic behavior remark-hpri-lp5
 remark local-precedence 5
#
qos policy remark-hpri-traffic
 classifier match-hpri-traffic behavior remark-hpri-lp5
#
 stp global enable
