{#路由#}
{% for upper in data.api_json.new_upper_list %}
{% if upper.ipv6 %}
{# IPv6: 根据掩码计算同网段另一个可用地址 /127只有2个地址,交替使用 #}
{% set ipv6_parts = upper.ipv6.split('/') %}
{% set ipv6_addr = ipv6_parts[0] %}
{% set ipv6_mask = ipv6_parts[1]|int %}
{% set last_sep = ipv6_addr.rfind(':') %}
{% set ipv6_prefix = ipv6_addr[:last_sep] %}
{% set ipv6_suffix_hex = ipv6_addr[last_sep+1:] %}
{# 将十六进制后缀转为数字,判断奇偶,交换 #}
{% set suffix_num = ipv6_suffix_hex|int(base=16) %}
{% if suffix_num % 2 == 0 %}
{% set next_suffix = suffix_num + 1 %}
{% else %}
{% set next_suffix = suffix_num - 1 %}
{% endif %}
{% set ipv6_next_hop = ipv6_prefix ~ ':' ~ ('%x' % next_suffix) %}
 ipv6 route-static :: 0 {{ upper.switch_port }} {{ ipv6_next_hop }}
{% endif %}
{% endfor %}
{% for upper in data.api_json.new_upper_list %}
{% if upper.ip %}
{# IPv4: 根据掩码计算同网段另一个可用地址 /30有4个地址,取网络地址+1或+2 #}
{% set ip_parts = upper.ip.split('/') %}
{% set ip_addr = ip_parts[0] %}
{% set ip_mask = ip_parts[1]|int %}
{% set ip_octets = ip_addr.split('.') %}
{% set last_octet = ip_octets[3]|int %}
{# 对于/30网段,有效地址为网络地址+1和+2,本机地址为.2时下一跳为.1 #}
{% if ip_mask == 30 %}
{% if last_octet % 4 == 2 %}
{% set next_hop_last = last_octet - 1 %}
{% else %}
{% set next_hop_last = last_octet + 1 %}
{% endif %}
{% set ip_next_hop = ip_octets[0] ~ '.' ~ ip_octets[1] ~ '.' ~ ip_octets[2] ~ '.' ~ next_hop_last %}
{% else %}
{# 其他掩码的情况,简单处理为+1或-1 #}
{% set ip_next_hop = ip_octets[0] ~ '.' ~ ip_octets[1] ~ '.' ~ ip_octets[2] ~ '.' ~ (last_octet - 1) %}
{% endif %}
 ip route-static 0.0.0.0 0 {{ upper.switch_port }} {{ ip_next_hop }}
{% endif %}
{% endfor %}
