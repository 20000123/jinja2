{# 聚合口配置 #}
{% if out_switch.to_iin and out_switch.to_iin != '' %}
interface AggregatePort 99
 port link-type trunk
 port trunk permit vlan 1 10 20
 link-aggregation mode dynamic
 stp edged-port
{% endif %}
{# 聚合口配置结束 #}
#
interface NULL0
#
{#interface vlan相关配置#}
interface Vlan-interface1
 ip address {{data.api_json.node_list[0].ext.ilo_gw[0]}} {{data.api_json.node_list[0].ext.ilo_netmask[0]}}
#
{% if out_switch.out_ip is defined and out_switch.out_ip and out_switch.out_ip != '' %}
interface Vlan-interface10
 description EX-Sevice-GW
 ip address {{ out_switch.out_ip }} {{ data.api_json.new_server_list[0].isp[0].netmask }}
{% if out_switch.ipv6_ip is defined and out_switch.ipv6_ip and out_switch.ipv6_ip != '' %}
 ipv6 address {{ out_switch.ipv6_ip }}/{{ data.api_json.new_server_list[0].isp[0].ipv6_mask }}
 ospfv3 1 area 0.0.0.0
{% endif %}
{% endif %}
#
{% if out_switch.in_ip is defined and out_switch.in_ip and out_switch.in_ip != '' %}
interface Vlan-interface20
 description IN-Sevice-GW
 ip address {{ out_switch.in_ip }} {{data.api_json.node_list[0].ext.in_netmask}}
{% endif %}
{#interface vlan相关配置#}
#
{#全端口配置开始#}
{# 遍历49-56口：FortyGigE1/0/49 到 1/0/54 #}
{% for port_num in range(49, 55) %}
{% set port_name = 'FortyGigE1/0/' ~ port_num %}
interface {{ port_name }}
{% set ns = namespace(is_upper=false) %}
{% for upper in data.api_json.new_upper_list %}
{% if upper.switch_port == port_name %}
{% set ns.is_upper = true %}
 port link-mode route
 description TO_ISP
{% set upper_ip_addr = upper.ip.split('/')[0] %}
 ip address {{ upper_ip_addr }} 255.255.255.252
 packet-filter ipv6 3007 inbound
 packet-filter 3001 inbound
 qos wfq byte-count
 qos wfq af2 group 1 byte-count 5
 qos wfq af3 group 1 byte-count 15
 qos wfq ef group sp
 qos bandwidth queue af3 min 2200000
 qos bandwidth queue ef min 2000000
{% if upper.ipv6 %}
 ipv6 address {{ upper.ipv6 }}
{% endif %}
{% endif %}
{% endfor %}
#
{% endfor %}
interface M-GigabitEthernet0/0/0
#
{% for port_num in range(1, 49) %}
{% set port_name = 'Ten-GigabitEthernet1/0/' ~ port_num %}
interface {{ port_name }}

{# 判断1：是否为上联口 upper_list #}
{% set ns = namespace(is_upper=false, is_server_port=false) %}
{% for upper in data.api_json.new_upper_list %}
{% if upper.switch_port == port_name %}
{% set ns.is_upper = true %}
 port link-mode route
 description TO_ISP
{% set upper_ip_addr = upper.ip.split('/')[0] %}
 ip address {{ upper_ip_addr }} 255.255.255.252
 packet-filter ipv6 3007 inbound
 packet-filter 3001 inbound
 qos wfq byte-count
 qos wfq af2 group 1 byte-count 5
 qos wfq af3 group 1 byte-count 15
 qos wfq ef group sp
 qos bandwidth queue af3 min 2200000
 qos bandwidth queue ef min 2000000
{% if upper.ipv6 %}
 ipv6 address {{ upper.ipv6 }}
{% endif %}
{% endif %}
{% endfor %}

{# 判断2：非上联口 → 服务器端口 #}
{% if not ns.is_upper %}
{% for server in data.api_json.new_server_list %}
{% if server.switch_port1.sn == out_sn and server.switch_port1.port == port_name %}
{% set ns.is_server_port = true %}
 port link-mode bridge
 port access vlan 10
 stp edged-port
 qos trust dscp
{% elif server.switch_port2.sn == out_sn and server.switch_port2.port == port_name %}
{% set ns.is_server_port = true %}
{% if server.type == 'lvs' %}
 port link-mode bridge
 port access vlan 10
{% else %}
 port link-mode bridge
 port access vlan 20
{% endif %}
 stp edged-port
 qos trust dscp
{% endif %}
{% endfor %}
{% endif %}

{# 判断3：级联口 #}
{% if not ns.is_upper and not ns.is_server_port %}
{% for sw in data.api_json.new_switch_list %}
{% if sw.type == "out" and sw.sn == out_sn %}
{% if sw.to_iin %}
{% for link in sw.to_iin %}
{% if link.src.port == port_name %}
 port link-mode bridge
 description DownLink_{{ in_hostname }}
 port link-type trunk
 port trunk permit vlan 1 10 20
 stp edged-port
 port link-aggregation group 99
{% endif %}
{% endfor %}
{% endif %}
{% if sw.to_mgt %}
{% for link in sw.to_mgt %}
{% if link.src.port == port_name %}
 description {{ mg_hostname }}
{% endif %}
{% endfor %}
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
#
{% endfor %}
{#全端口配置结束#}
